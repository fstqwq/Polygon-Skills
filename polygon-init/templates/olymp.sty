\def\s@tm@cr@s{
    \def\widthin##1{\exmpwidinf=##1\relax}
    \def\widthout##1{\exmpwidouf=##1\relax}
    \def\stretchin##1{\advance\exmpwidinf by ##1\relax}
    \def\stretchout##1{\advance\exmpwidouf by ##1\relax}
    \@ifstar{
        \error Star must not be used in example environment any more
    }
}

% This is magic, which delete space after verbatiminput
\addto@hook{\every@verbatim}{\topsep=0pt\relax}

% :FIXME:
\newcounter{exmpnum}
\newenvironment{example}[1][]{
    \s@tm@cr@s#1
    \setcounter{exmpnum}{0}%
    \ttfamily\obeylines\obeyspaces\frenchspacing
    \newcommand{\exmp}[2]{
    \ifdefined\NoExamples\else%
        \ifnum\value{exmpnum}=0\relax
            \vspace{0.6\baselineskip}%
        \fi
        \stepcounter{exmpnum}%
        \noindent\hspace*{\wfSampleLeft}%
        \begin{minipage}{\wfSampleTableWidth}
            \hbox to \wfSampleTableWidth{%
                {\sffamily\bfseries Sample Input \arabic{exmpnum}}%
                \hfil
                {\sffamily\bfseries Sample Output \arabic{exmpnum}}%
                \hfil
            }%
            \par\smallskip
            \setlength{\extrarowheight}{1mm}
            \begin{tabular}{|p{\exmpwidinf}|p{\exmpwidouf}|}
                \hline
                \begin{minipage}[t]{\exmpwidinf}\rightskip=0pt plus 1fill\relax##1\smallskip\end{minipage}&
                \begin{minipage}[t]{\exmpwidouf}\rightskip=0pt plus 1fill\relax##2\smallskip\end{minipage}\\
                \hline
            \end{tabular}
        \end{minipage}
        \par\medskip
    \fi%
    }
    \newcommand{\exmpinteract}[2]{
    \ifdefined\NoExamples\else%
        \ifnum\value{exmpnum}=0\relax
            \vspace{0.6\baselineskip}%
        \fi
        \stepcounter{exmpnum}%
        \noindent\hspace*{\wfSampleLeft}%
        \begin{tabular*}{\wfSampleTableWidth}{@{}l@{\extracolsep{\fill}}c@{\extracolsep{\fill}}r@{}}%
            \sffamily\bfseries Read &
            \sffamily\bfseries Sample Interaction \arabic{exmpnum} &
            \sffamily\bfseries Write
        \end{tabular*}%
        \par
        \noindent\hspace*{\wfSampleLeft}%
        \begin{minipage}{\wfSampleTableWidth}
            \begin{tabular}{|p{\exmpwidinf}|p{\exmpwidouf}|}
                \hline
                \begin{minipage}[t]{\exmpwidinf}\rightskip=0pt plus 1fill\relax##1\medskip\end{minipage}&
                \begin{minipage}[t]{\exmpwidouf}\rightskip=0pt plus 1fill\relax##2\medskip\end{minipage}\\
                \hline
            \end{tabular}
        \end{minipage}
        \par\medskip
    \fi%
    }
    \newcommand{\exmpinteractfile}[2]{%
        \exmpinteract{\verbatiminput{##1}}{\verbatiminput{##2}}%
    }

    \newcommand{\exmpfile}[2]{
    \ifdefined\NoExamples\else%
       \exmp{
          \verbatiminput{##1}
       }{
          \verbatiminput{##2}
       }%
    \fi%
    }
}{
}

\newcounter{exmpnumtwice}
\newcounter{exmpnumtwicepair}
\newenvironment{exampletwice}[1][]{
    \s@tm@cr@s#1
    \setcounter{exmpnumtwice}{0}%
    \setcounter{exmpnumtwicepair}{0}%
    \ttfamily\obeylines\obeyspaces\frenchspacing
    \newcommand{\exmp}[2]{
    \ifdefined\NoExamples\else%
        \ifnum\value{exmpnumtwice}=0\relax
            \vspace{0.6\baselineskip}%
        \fi
        \stepcounter{exmpnumtwice}%
        \ifodd\value{exmpnumtwice}
            \stepcounter{exmpnumtwicepair}%
            \edef\wfPassIndex{1}%
        \else
            \edef\wfPassIndex{2}%
        \fi
        \edef\wfSampleIndex{\arabic{exmpnumtwicepair}}%
        \noindent\hspace*{\wfSampleLeft}%
        \begin{tabular*}{\wfSampleTableWidth}{@{}l@{\extracolsep{\fill}}c@{\extracolsep{\fill}}r@{}}%
            \sffamily\bfseries Sample Input \wfSampleIndex &
            \sffamily\bfseries Pass \wfPassIndex &
            \sffamily\bfseries Sample Output \wfSampleIndex
        \end{tabular*}%
        \par
        \noindent\hspace*{\wfSampleLeft}%
        \begin{minipage}{\wfSampleTableWidth}
            \begin{tabular}{|p{\exmpwidinf}|p{\exmpwidouf}|}
                \hline
                \begin{minipage}[t]{\exmpwidinf}\rightskip=0pt plus 1fill\relax##1\smallskip\end{minipage}&
                \begin{minipage}[t]{\exmpwidouf}\rightskip=0pt plus 1fill\relax##2\smallskip\end{minipage}\\
                \hline
            \end{tabular}
        \end{minipage}
        \par\medskip
    \fi%
    }
    \newcommand{\exmpinteract}[2]{
    \ifdefined\NoExamples\else%
        \ifnum\value{exmpnumtwice}=0\relax
            \vspace{0.6\baselineskip}%
        \fi
        \stepcounter{exmpnumtwice}%
        \ifodd\value{exmpnumtwice}
            \stepcounter{exmpnumtwicepair}%
            \edef\wfPassIndex{1}%
        \else
            \edef\wfPassIndex{2}%
        \fi
        \edef\wfSampleIndex{\arabic{exmpnumtwicepair}}%
        \noindent\hspace*{\wfSampleLeft}%
        \begin{tabular*}{\wfSampleTableWidth}{@{}l@{\extracolsep{\fill}}c@{\extracolsep{\fill}}r@{}}%
            \sffamily\bfseries Read &
            \sffamily\bfseries Sample \wfSampleIndex, Pass \wfPassIndex &
            \sffamily\bfseries Write
        \end{tabular*}%
        \par
        \noindent\hspace*{\wfSampleLeft}%
