% -- Setup margins --
%
% Tex defines to large margins for our purposes. 
% So we redefine this to use paper more efficiently
%

\newlength{\thelinewidth}

\if@landscape
    \if@twocolumn
    \else
        \error Landscape is only supported for two column mode
    \fi

    \ifcase\@ptsize % 10 pt
        \hoffset=-15mm
        \voffset=-35mm
        \textheight=165mm
        \textwidth=272mm
    \or % 11 pt
        \hoffset=-13mm
        \voffset=-36mm
        \textheight=166mm
        \textwidth=272mm
    \or % 12 pt
        \hoffset=-12mm
        \voffset=-35mm
        \textheight=162mm
        \textwidth=268mm
    \fi
\else
    \ifcase\@ptsize % 10 pt
        \hoffset=-26.5mm
        \voffset=-35mm
        \textheight=250mm
        \textwidth=175mm
    \or % 11 pt
        \hoffset=-25mm
        \voffset=-37.5mm
        \textheight=255mm
        \textwidth=175mm
    \or % 12 pt
        \hoffset=-20mm
        \voffset=-35mm
        \textheight=245mm
        \textwidth=175mm
    \fi

    \if@twocolumn
        \hoffset=-14.3mm
        \voffset=-38mm
        \textheight=255mm
        \textwidth=188mm
    \fi
\fi

\if@twocolumn
    \thelinewidth=0.47\textwidth
\else
    \thelinewidth=\textwidth
\fi

% -- End of setup margins --

